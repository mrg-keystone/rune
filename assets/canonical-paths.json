{
  "$forbiddenDirNames": ["lib", "modules", "internal"],
  "$looseFileNames": ["utils", "helpers", "common", "shared", "util", "helper"],
  "$rootFiles": ["deno", "deno.lock", "README", ".gitignore", "TODOS"],

  "bootstrap/": {
    "$desc": "Composition root — wires modules, starts the app",
    "mod": { "ext": [".ts"], "desc": "app entry point and module wiring" },
    "config": {
      "ext": [".ts"],
      "desc": "environment and configuration loading"
    }
  },
  "src/": {
    "core/": {
      "$desc": "Shared kernel — importable from any module",
      "business/": {
        "<feature>/": [
          {
            "template": {
              "ext": [".html"],
              "desc": "HTML template for UI rendering",
              "optional": true
            },
            "styles": {
              "ext": [".css"],
              "desc": "scoped styles for this feature",
              "optional": true
            },
            "mod": {
              "ext": [".ts"],
              "desc": "pure logic, no I/O or side effects"
            },
            "test": { "ext": [".ts"], "desc": "unit tests for the sibling mod" }
          },
          {
            "base/": {
              "mod": {
                "ext": [".ts"],
                "desc": "shared base implementation across variants"
              },
              "test": {
                "ext": [".ts"],
                "desc": "tests for the base implementation"
              }
            },
            "implementations/": {
              "<variant-name>/": {
                "mod": {
                  "ext": [".ts"],
                  "desc": "variant-specific implementation"
                },
                "test": { "ext": [".ts"], "desc": "tests for this variant" }
              }
            },
            "poly-mod": {
              "ext": [".ts"],
              "desc": "barrel re-export for the active variant"
            }
          }
        ]
      },
      "data/": {
        "<service>/": {
          "mod": { "ext": [".ts"], "desc": "adapter for an external system" },
          "smk.test": {
            "ext": [".ts"],
            "desc": "smoke test, verifies connectivity"
          }
        }
      },
      "dto/": {
        "<name>": { "ext": [".ts"], "desc": "Zod schema and type definition" }
      }
    },
    "<module-name>/": {
      "$desc": "Isolated module — imports only from core or itself",
      "mod-root": {
        "ext": [".ts"],
        "desc": "public API, only external import surface"
      },
      "<module-name>": {
        "ext": [".rune"],
        "desc": "module-level rune spec — the source this module is generated from",
        "optional": true
      },
      "domain/": {
        "business/": {
          "<feature>/": [
            {
              "template": {
                "ext": [".html", ".tsx"],
                "desc": "HTML template for UI rendering",
                "optional": true
              },
              "styles": {
                "ext": [".css"],
                "desc": "scoped styles for this feature",
                "optional": true
              },
              "sig": {
                "ext": [".ts"],
                "desc": "spec-owned signatures, regenerated by rune sync",
                "optional": true
              },
              "mod": {
                "ext": [".ts"],
                "desc": "pure logic, no I/O or side effects"
              },
              "test": {
                "ext": [".ts"],
                "desc": "unit tests for the sibling mod"
              }
            },
            {
              "base/": {
                "mod": {
                  "ext": [".ts"],
                  "desc": "shared base implementation across variants"
                },
                "test": {
                  "ext": [".ts"],
                  "desc": "tests for the base implementation"
                }
              },
              "implementations/": {
                "<variant-name>/": {
                  "mod": {
                    "ext": [".ts"],
                    "desc": "variant-specific implementation"
                  },
                  "test": { "ext": [".ts"], "desc": "tests for this variant" }
                }
              },
              "poly-mod": {
                "ext": [".ts"],
                "desc": "barrel re-export for the active variant"
              }
            }
          ]
        },
        "data/": {
          "<service>/": {
            "sig": { "ext": [".ts"], "desc": "spec-owned signatures, regenerated by rune sync", "optional": true },
            "mod": { "ext": [".ts"], "desc": "adapter for an external system" },
            "smk.test": {
              "ext": [".ts"],
              "desc": "smoke test, verifies connectivity"
            }
          }
        },
        "coordinators/": {
          "<process>/": {
            "template": {
              "ext": [".html", ".tsx"],
              "desc": "HTML template for UI rendering",
              "optional": true
            },
            "styles": {
              "ext": [".css"],
              "desc": "scoped styles",
              "optional": true
            },
            "mod": {
              "ext": [".ts"],
              "desc": "orchestrates business + data layers"
            },
            "int.test": {
              "ext": [".ts"],
              "desc": "integration test for the workflow"
            }
          }
        }
      },
      "entrypoints/": {
        "<name>/": {
          "template": {
            "ext": [".html", ".tsx"],
            "desc": "HTML template for UI rendering",
            "optional": true
          },
          "styles": {
            "ext": [".css"],
            "desc": "scoped styles",
            "optional": true
          },
          "mod": {
            "ext": [".ts"],
            "desc": "exposes functionality to the outside world"
          },
          "e2e.test": {
            "ext": [".ts"],
            "desc": "cypress end-to-end tests for this entry point"
          }
        }
      },
      "dto/": {
        "<name>": {
          "ext": [".ts"],
          "desc": "class validator and class transformer type definition"
        }
      }
    }
  },
  "specs/": {
    "$desc": "Rune spec files — one per module",
    "<name>": { "ext": [".rune"], "desc": "rune spec for a module" }
  },
  "fixtures/": {
    "<category>/": {
      "$ignore": "*"
    }
  },
  "assets/": {
    "<category>/": {
      "<name>": "static asset"
    }
  },
  "dist/": {
    "$desc": "Compiled output — not source-controlled",
    "$ignore": "*"
  }
}
