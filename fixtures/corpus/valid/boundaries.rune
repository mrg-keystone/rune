[REQ] sync.run(SyncDto): ResultDto
    db:store.read(IdDto): RecordDto
      not-found
    fs:disk.load(IdDto): RecordDto
      not-found
    mq:queue.publish(RecordDto): void
      timeout
    ex:api.fetch(IdDto): RecordDto
      timeout not-found
    os:blob.put(RecordDto): void
      timeout
    lg:audit.write(RecordDto): void
    [RET] ResultDto

[DTO] SyncDto: id
    what to sync

[DTO] IdDto: id
    an identifier

[DTO] RecordDto: id, payload
    a stored record

[DTO] ResultDto: id
    the sync result

[TYP] payload: string
    the payload

[SRV] (SIDECAR)db: DB_URL
    the primary datastore
    @docs https://docs.example.com/db

[SRV] (SIDECAR)fs: FS_ROOT
    file storage
    @docs https://docs.example.com/fs

[SRV] (SIDECAR)mq: MQ_URL
    message queue
    @docs https://docs.example.com/mq

[SRV] (HTTP)ex: EX_URL
    external http service
    @docs https://docs.example.com/ex

[SRV] (SIDECAR)os: OS_ENDPOINT
    object storage
    @docs https://docs.example.com/os

[SRV] (SIDECAR)lg: LOG_URL
    log sink
    @docs https://docs.example.com/lg

