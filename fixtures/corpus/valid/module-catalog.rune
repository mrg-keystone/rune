[MOD] catalog

[REQ] product.list(ListDto): ProductsDto
    db:product.query(ListDto): ProductsDto
      timeout
    [RET] ProductsDto

[DTO] ListDto: page
    a paged product listing request

[DTO] ProductsDto: items
    a page of products

[TYP] page: number
    the page
[TYP] items: string
    the items

[SRV] (SIDECAR)db: DB_URL
    the primary datastore
    @docs https://docs.example.com/db

