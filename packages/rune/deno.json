{
  "tasks": {
    "hooks": "git config core.hooksPath .githooks",
    "setup": "deno run --allow-read --allow-run --allow-write src/bootstrap/config.ts && deno run --allow-read --allow-write scripts/gen-shape-docs.ts",
    "check": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run src/bootstrap/mod.ts",
    "dev": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run src/bootstrap/mod.ts",
    "gen": "deno run --allow-read --allow-write generate.mjs",
    "studio": "cd rune-studio && deno task dev",
    "build:rust": "cd lang && cargo build --release",
    "compile": "deno task setup && deno compile --allow-read --allow-write --allow-net --allow-env --allow-run -o dist/rune src/bootstrap/mod.ts",
    "build": "deno task compile && deno task build:rust && mkdir -p dist && cp lang/target/release/rune-lsp lang/target/release/rune-syntax dist/",
    "install": "sh scripts/install.sh --dev",
    "install:release": "sh scripts/install.sh",
    "uninstall": "sh scripts/uninstall.sh",
    "verify": "deno run -A scripts/verify.ts"
  },
  "imports": {
    "@/": "./src/",
    "@core/": "./src/core/",
    "@rune/": "./src/rune/",
    "@keywords": "./keywords.json",
    "#zod": "npm:zod",
    "#std/assert": "jsr:@std/assert",
    "#std/path": "jsr:@std/path",
    "class-validator": "npm:class-validator@^0.14",
    "class-transformer": "npm:class-transformer@^0.5",
    "reflect-metadata": "npm:reflect-metadata@0.1.13",
    "@mrg-keystone/keep": "jsr:@mrg-keystone/keep@^1",
    "#assert": "jsr:@mrg-keystone/keep@^1/assert",
    "#api-doc": "jsr:@danet/swagger@^2.1.1/decorators"
  },
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "exclude": [
    "src/calendar/",
    "src/client/",
    "src/engine/",
    "src/providers/",
    "src/submit/",
    "src/sync/",
    "src/todos/"
  ]
}
