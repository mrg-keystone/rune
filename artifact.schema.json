{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "vars": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "palette": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "tags": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tag": {
            "type": "string",
            "pattern": "^\\[[A-Z]+(:[a-z]+)?\\]$"
          },
          "label": {
            "type": "string"
          },
          "indent": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "follows": {
            "type": "string",
            "enum": [
              "signature",
              "poly",
              "typedef",
              "dtodef",
              "identifier",
              "case",
              "value",
              "none"
            ]
          },
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowFunctionName": {
            "type": "boolean"
          },
          "color": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "codegen": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                }
              },
              "required": [
                "path",
                "body"
              ],
              "additionalProperties": false
            }
          },
          "group": {
            "type": "string"
          },
          "syntax": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "tag",
          "label",
          "indent",
          "follows"
        ],
        "additionalProperties": false
      }
    },
    "modifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "token": {
            "type": "string",
            "pattern": "^:[a-z]+$"
          },
          "label": {
            "type": "string"
          },
          "appliesTo": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "syntax": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "token",
          "appliesTo"
        ],
        "additionalProperties": false
      }
    },
    "boundaries": {
      "type": "object",
      "properties": {
        "color": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "prefixes": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "prefixes"
      ],
      "additionalProperties": false
    },
    "builtins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tokens": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "architecture": {},
    "lint": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "enum": [
              "spec",
              "generated"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "params": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "message": {
            "type": "string"
          },
          "locked": {
            "type": "boolean"
          },
          "owner": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "target",
          "severity",
          "enabled",
          "message"
        ],
        "additionalProperties": false
      }
    },
    "bindings": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "from": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "MOD",
                "REQ",
                "STEP",
                "PLY",
                "CSE",
                "BOUNDARY",
                "DTO",
                "TYP",
                "ENT"
              ]
            }
          },
          "caseStyle": {
            "type": "string",
            "enum": [
              "kebab",
              "camel",
              "pascal",
              "lower"
            ]
          },
          "stripSuffix": {
            "type": "string"
          },
          "coreOnly": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "from",
          "caseStyle",
          "coreOnly"
        ],
        "additionalProperties": false
      }
    },
    "codegen": {
      "type": "object",
      "properties": {
        "templates": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "templates"
      ],
      "additionalProperties": false
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "vars": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "id",
          "vars"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "name",
    "schemaVersion",
    "tags",
    "boundaries",
    "builtins",
    "tokens",
    "lint"
  ],
  "additionalProperties": false
}
