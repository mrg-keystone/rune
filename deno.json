{
  "workspace": [
    "./packages/rune",
    "./packages/keep"
  ],
  "tasks": {
    "check:lockstep": "deno run --allow-read packages/rune/scripts/check-keep-lockstep.ts",
    "verify": "deno task check:lockstep && cd packages/rune && deno task verify",
    "build:rune": "cd packages/rune && deno task build",
    "test:keep": "cd packages/keep && deno task test",
    "check:keep-jsr": "cd packages/keep && deno task check:jsr"
  }
}
